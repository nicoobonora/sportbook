# ══════════════════════════════════════════════════════════
# SportBook — Variabili d'Ambiente
# Copia questo file in .env.local e compila i valori
# ══════════════════════════════════════════════════════════

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (Email transazionali) ──
# Lascia vuoto per sviluppo locale (le email vengono loggate in console)
RESEND_API_KEY=re_your-api-key

# ── Super Admin ──
# Lista email separate da virgola che hanno accesso super-admin
SUPER_ADMIN_EMAILS=admin@prenotauncampetto.it

# ── App Configuration ──
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# ── Preview Token ──
# Secret per firmare i token di anteprima (cambialo in produzione!)
PREVIEW_TOKEN_SECRET=change-this-to-a-random-secret

# ── Sentry (Error Monitoring) ──
# Lascia vuoto per disabilitare Sentry in sviluppo locale
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=prenotauncampetto
SENTRY_AUTH_TOKEN=
